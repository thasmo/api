{
	"type": "module",
	"private": true,
	"packageManager": "pnpm@11.15.1",
	"engines": {
		"node": ">=22",
		"pnpm": ">=10"
	},
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"deploy": "wrangler deploy",
		"upload": "wrangler versions upload",
		"prepare": "concurrently --group --prefix-colors 'auto' 'pnpm:prepare:*'",
		"prepare:husky": "husky",
		"lint": "concurrently --group --prefix-colors 'auto' 'pnpm:lint:*'",
		"lint:eslint": "eslint .",
		"lint:knip": "knip --no-progress",
		"lint:cspell": "cspell --no-progress --no-summary --dot --no-must-find-files .",
		"fix": "concurrently --group --prefix-colors 'auto' 'pnpm:fix:*'",
		"fix:eslint": "eslint --fix .",
		"fix:knip": "knip --fix --no-progress --workspace ."
	},
	"dependencies": {
		"@astrojs/cloudflare": "^14.0.0",
		"@dotenvx/dotenvx": "^2.0.0",
		"astro": "^7.0.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.0.0",
		"@somehow-digital/commitlint-config": "^1.0.0",
		"@somehow-digital/cspell-dictionary": "^2.0.0",
		"@somehow-digital/eslint-config": "^5.0.0",
		"concurrently": "^10.0.0",
		"cspell": "^10.0.0",
		"eslint": "^10.0.0",
		"husky": "^9.0.11",
		"knip": "^6.0.0",
		"lint-staged": "^17.0.0",
		"wrangler": "^4.54.0"
	}
}
